# Port the HTTP server listens on
PORT=3000

# Maximum number of PDF renders processed concurrently.
# Above this limit, requests receive 429 Too Many Requests.
MAX_CONCURRENT_RENDERS=4

# Overall wall-clock timeout (ms) for a single render, independent of any
# per-step timeouts set inside the request body (gotoOptions.timeout, etc).
REQUEST_TIMEOUT_MS=60000

# Max JSON request body size (mostly relevant for large `html` payloads).
MAX_BODY_SIZE=2mb

# --- Security ---

# SSRF protection: by default, requests targeting private/loopback/
# link-local/cloud-metadata addresses (e.g. 127.0.0.1, 10.0.0.0/8,
# 169.254.169.254) are blocked, for both the top-level `url` and any
# sub-request the page makes. Only set to true if you intentionally run this
# service inside a trusted network and need it to reach internal targets.
ALLOW_PRIVATE_NETWORK_TARGETS=false

# Per-IP rate limiting on POST /pdf.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Number of reverse-proxy hops to trust for X-Forwarded-For (Coolify/Traefik
# sits in front of this service as one hop by default).
TRUST_PROXY_HOPS=1
